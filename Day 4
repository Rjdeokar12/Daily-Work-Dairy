-- Joins queries

-- 1. INNER JOIN
SELECT c.Customer_name, o.Order_amount
FROM CUSTOMER c
INNER JOIN ORDERS o 
ON c.Customer_id = o.Customer_id;

--  INNER JOIN using WHERE Clause
SELECT c.Customer_name, o.Order_amount
FROM CUSTOMER c
INNER JOIN ORDERS o 
ON c.Customer_id = o.Customer_id
WHERE o.Order_status = 'Delivered';

-- 2. LEFT JOIN
SELECT c.Customer_name, o.Order_amount
FROM CUSTOMER c
LEFT JOIN ORDERS o
ON c.Customer_id = o.Customer_id;

SELECT c.Customer_name, o.Order_status
FROM CUSTOMER c
LEFT JOIN ORDERS o
ON c.Customer_id = o.Customer_id
AND o.Order_status = 'Delivered';

SELECT C.Customer_id, C.Customer_name, COUNT(O.Customer_id) AS Total_no_of_order
FROM CUSTOMER C
LEFT JOIN ORDERS O
ON C.Customer_id = O.Customer_id
GROUP BY C.Customer_id, C.Customer_name
HAVING  COUNT(O.Customer_id) > 1;

SELECT C.Customer_id, C.Customer_name, COALESCE(SUM(O.Order_amount), 0) AS Total_purchase
FROM CUSTOMER C
LEFT JOIN ORDERS O
ON C.Customer_id = O.Customer_id
GROUP BY C.Customer_id, C.Customer_name
ORDER BY Total_purchase DESC
LIMIT 2;

