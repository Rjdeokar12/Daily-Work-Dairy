USE sql_practice;

ALTER TABLE ORDERS
ADD COLUMN Order_date DATE;

UPDATE ORDERS
SET Order_date = CURDATE();

SELECT * FROM ORDERS;

UPDATE ORDERS
SET Order_date = '2024-02-14'
WHERE Order_status = 'Cancelled';

-- Q1 “Find total revenue per customer”
SELECT 
	C.Customer_id, 
    C.Customer_name, 
    COALESCE(SUM(O.Order_amount), 0) AS Revenue_per_customer
    
FROM CUSTOMER C
LEFT JOIN ORDERS O
ON C.Customer_id = O.Customer_id
GROUP BY 
	C.Customer_id, 
    C.Customer_name;

-- Q2 Find total revenue per city and return the top 2 cities based on revenue.
SELECT 
	C.City,
    COALESCE(SUM(O.Order_amount), 0) AS Revenue_per_city
    
FROM CUSTOMER C
INNER JOIN ORDERS O
ON C.Customer_id = O.Customer_id
GROUP BY C.City
ORDER BY Revenue_per_city DESC
LIMIT 2;

-- Q3 Find customers who have placed more than 1 order
SELECT 
	C.Customer_id,
    C.Customer_name,
    COUNT(O.Order_id) AS No_of_orders
FROM CUSTOMER C
INNER JOIN ORDERS O
ON C.Customer_id = O.Customer_id
GROUP BY
	C.Customer_id, 
    C.Customer_name
HAVING COUNT(O.Order_id) > 1;

-- Q4 Find customers who have not placed any orders
SELECT 
	C.Customer_id,
    C.Customer_name,
    COUNT(O.Order_id) AS No_of_orders
FROM CUSTOMER C
LEFT JOIN ORDERS O
ON C.Customer_id = O.Customer_id
GROUP BY
	C.Customer_id, 
    C.Customer_name
HAVING COUNT(O.Order_id) = 0;

-- Alternative approach
SELECT 
	C.Customer_id,
    C.Customer_name
FROM CUSTOMER C
WHERE Customer_id NOT IN (
	SELECT Customer_id FROM ORDERS
);

-- Q5 Find average order amount per customer
SELECT 
	C.Customer_id,
    C.Customer_name,
    COALESCE(ROUND(AVG(O.Order_amount), 2), 0) AS Average_amount_Customer
FROM CUSTOMER C
LEFT JOIN ORDERS O
ON C.Customer_id = O.Customer_id
GROUP BY
	C.Customer_id, 
    C.Customer_name
ORDER BY Average_amount_Customer DESC;
